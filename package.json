{
  "name": "horse",
  "version": "0.7.2",
  "description": "HorseMD Markdown Editor",
  "author": "mini_md",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BND-1/horseMD.git"
  },
  "homepage": "https://github.com/BND-1/horseMD#readme",
  "bugs": {
    "url": "https://github.com/BND-1/horseMD/issues"
  },
  "main": "out/main/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "cross-env ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build",
    "preview": "cross-env ELECTRON_RUN_AS_NODE= electron-vite preview",
    "start": "cross-env ELECTRON_RUN_AS_NODE= electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:dir": "electron-vite build && electron-builder --dir",
    "build:mobile": "vite build --config vite.mobile.config.mjs",
    "shortcuts:inventory": "node scripts/export-shortcut-inventory.mjs",
    "test:source-map": "node scripts/test-editor-source-map.mjs",
    "test:markdown-preservation": "node scripts/test-markdown-source-preservation.mjs",
    "test:issue-77-ui": "node scripts/test-issue-77-source-preservation-ui.mjs",
    "test:issue-84-ui": "node scripts/test-issue-84-image-alt-ui.mjs",
    "test:external-change-warning-ui": "node scripts/test-external-change-warning-ui.mjs",
    "test:issue-79-ui": "node scripts/test-issue-79-list-spacing-ui.mjs",
    "test:outline-reorder": "node scripts/test-outline-reorder.mjs",
    "test:issue-82-ui": "node scripts/test-issue-82-outline-reorder-ui.mjs",
    "test:keybindings": "node scripts/test-keybindings.mjs",
    "test:keybindings-ui": "node scripts/test-settings-keybindings-ui.mjs",
    "test:keybindings-persistence-ui": "node scripts/test-keybindings-persistence-ui.mjs",
    "test:keybindings-runtime-ui": "node scripts/test-keybindings-runtime-ui.mjs",
    "test:menu-keybindings-ui": "node scripts/test-menu-keybindings-ui.mjs",
    "test:settings-ui": "node scripts/test-settings-view-ui.mjs",
    "test:settings-layout-ui": "node scripts/test-settings-layout-ui.mjs",
    "test:settings-update": "node scripts/test-settings-update.mjs",
    "test:settings-actions": "node scripts/test-settings-actions.mjs",
    "test:editor-style-settings-ui": "node scripts/test-editor-style-settings-ui.mjs",
    "test:command-palette-keybindings-ui": "node scripts/test-command-palette-keybindings-ui.mjs",
    "test:shortcuts": "npm run shortcuts:inventory && npm run test:keybindings && npm run test:keybindings-ui && npm run test:keybindings-persistence-ui && npm run test:keybindings-runtime-ui && npm run test:menu-keybindings-ui && npm run test:settings-ui && npm run test:settings-layout-ui && npm run test:settings-update && npm run test:settings-actions && npm run test:command-palette-keybindings-ui",
    "test:ui-regression": "node scripts/run-ui-regression.mjs",
    "test:source-find": "node scripts/test-source-find.mjs",
    "test:pdf-export": "node scripts/test-pdf-export-state.mjs && node scripts/test-latest-task-runner.mjs",
    "test:editor-registry": "node scripts/test-editor-api-registry.mjs",
    "test:pdf-ui": "node scripts/test-pdf-studio-ui.mjs",
    "test:editor-input": "node scripts/test-editor-inline-code.mjs && node scripts/test-editor-inline-math.mjs",
    "test:ui-layout": "node scripts/test-menu-position.mjs",
    "test:table-ui": "node scripts/test-table-scroll-ui.mjs",
    "test:pdf-table-ui": "node scripts/test-pdf-wide-table-ui.mjs",
    "test:math-ui": "node scripts/test-inline-math-ui.mjs",
    "test:issues-66-67-ui": "node scripts/test-issues-66-67-ui.mjs",
    "test:issues-70-72-ui": "node scripts/test-issues-70-72-ui.mjs",
    "test:issues-74-75-ui": "node scripts/test-issues-74-75-ui.mjs",
    "test:pdf-latex-ui": "node scripts/test-pdf-latex-ui.mjs",
    "test:web-paste-ui": "node scripts/test-web-paste-and-blank-ui.mjs",
    "test:lightbox-ui": "node scripts/test-lightbox-ui.mjs",
    "test:review": "node scripts/review-markup.test.mjs",
    "test:review-ui": "node scripts/test-review-ui.mjs",
    "test:security": "node scripts/test-main-security.mjs && node scripts/test-pdf-document.mjs",
    "test:filesystem": "node scripts/test-main-filesystem.mjs",
    "test:sidebar-inline-create-ui": "node scripts/test-sidebar-inline-create-ui.mjs",
    "test:sidebar-sync-menu-ui": "node scripts/test-sidebar-sync-menu-ui.mjs",
    "test:sync-workspaces": "node scripts/test-sync-workspaces.mjs",
    "test:sync-workspaces-ui": "node scripts/test-sync-workspaces-ui.mjs",
    "test:sync-plan": "node scripts/test-sync-plan.mjs",
    "test:sync-local-files": "node scripts/test-sync-local-files.mjs",
    "test:webdav-provider": "node scripts/test-webdav-provider.mjs",
    "test:webdav-apache": "node scripts/test-webdav-apache.mjs",
    "test:sync-engine": "node scripts/test-sync-engine.mjs",
    "test:sync-credentials": "node scripts/test-sync-credentials.mjs",
    "test:webdav-electron-sync": "node scripts/test-webdav-electron-sync.mjs",
    "test:s3-provider": "node scripts/test-s3-provider.mjs",
    "test:s3-electron-sync": "node scripts/test-s3-electron-sync.mjs",
    "test:watchers": "node scripts/test-main-watchers.mjs",
    "test:criticmarkup": "node scripts/test-strike-guard.mjs && node scripts/test-substitution-headless.mjs",
    "test:core": "npm run test:security && npm run test:pdf-export && npm run test:editor-registry && npm run test:filesystem && npm run test:watchers && npm run test:source-map && npm run test:review && npm run test:criticmarkup && npm run test:editor-input && npm run test:ui-layout",
    "cap:sync": "npm run build:mobile && cap sync",
    "cap:ios": "npm run build:mobile && cap sync ios && cap open ios",
    "cap:android": "npm run build:mobile && cap sync android && cap open android",
    "dist:android": "npm run build:mobile && cap sync android && cd android && ./gradlew assembleRelease",
    "guide:dev": "npm --prefix guide run dev",
    "guide:build": "npm --prefix guide run build",
    "guide:check": "npm --prefix guide run check",
    "guide:test:visual": "npm --prefix guide run test:visual",
    "guide:capture": "node scripts/capture-guide-screenshots.mjs"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capawesome/capacitor-file-picker": "^8.0.2",
    "@milkdown/crepe": "^7.6.5",
    "@smithy/protocol-http": "^5.3.6",
    "@smithy/signature-v4": "^5.6.6",
    "chokidar": "^4.0.3",
    "fast-xml-parser": "^5.10.0",
    "mdast-util-to-string": "^4.0.0",
    "mermaid": "^11.15.0",
    "pdfjs-dist": "^4.10.38",
    "pinyin-pro": "^3.28.1",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^10.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark-gfm": "^4.0.1",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.horsemd.app",
    "productName": "HorseMD",
    "files": [
      "out/**/*"
    ],
    "icon": "build/icon.ico",
    "publish": [
      {
        "provider": "github",
        "owner": "BND-1",
        "repo": "horseMD"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "fileAssociations": [
        {
          "ext": "md",
          "name": "Markdown Document",
          "role": "Editor"
        },
        {
          "ext": "markdown",
          "name": "Markdown Document",
          "role": "Editor"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "fileAssociations": [
        {
          "ext": "md",
          "name": "Markdown Document",
          "role": "Editor",
          "icon": "build/icon.ico"
        },
        {
          "ext": "markdown",
          "name": "Markdown Document",
          "role": "Editor",
          "icon": "build/icon.ico"
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons",
      "category": "Development",
      "maintainer": "mini_md",
      "vendor": "HorseMD",
      "fileAssociations": [
        {
          "ext": "md",
          "name": "Markdown Document",
          "role": "Editor",
          "mimeType": "text/markdown"
        },
        {
          "ext": "markdown",
          "name": "Markdown Document",
          "role": "Editor",
          "mimeType": "text/markdown"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "include": "build/installer.nsh"
    }
  }
}
